# Dependencies & build output
node_modules
**/node_modules
**/dist
**/*.tsbuildinfo

# Git / editor / OS
.git
.gitignore
.vscode
.idea
.DS_Store
*.swp

# Local harness state (never ship)
.harness
*.pid
*.log

# Environment files — only the example is allowed in build context
.env
.env.*
!.env.production.example

# Plan docs / design assets not needed at runtime
docs/plans/design

# Test artefacts / coverage
coverage
.nyc_output

# User data directory
~/.jasojeon

# Docker artefacts themselves don't need to be in the build context
docker-compose.yml
docker-compose.*.yml
