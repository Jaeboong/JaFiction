# Jasojeon hosted backend — production env template.
#
# Copy this file to `.env.production` on the deployment host and fill in the
# blanks. `.env.production` itself must NEVER be committed — it contains real
# secrets. `chmod 600 .env.production` after editing.
#
# Compose loads this file via `--env-file .env.production`.

# ---------- Public URL ----------
# Must be the punycode form, not Hangul. Node's URL parser + Fastify CORS
# comparisons operate on raw strings; using xn--... avoids IDN mismatches.
PUBLIC_BASE_URL=https://xn--2t1b49b33i.com

# ---------- Backend runtime ----------
NODE_ENV=production
PORT=4000

# 32+ byte secret used to sign session cookies.
# Generate with: openssl rand -hex 32
COOKIE_SECRET=

# ---------- Postgres ----------
POSTGRES_DB=jasojeon
POSTGRES_USER=jasojeon
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Note: DATABASE_URL is assembled inside docker-compose.yml from the POSTGRES_*
# vars above so you don't need to set it explicitly here.

# ---------- Redis ----------
# Compose resolves `redis` via the default network.
REDIS_URL=redis://redis:6379

# ---------- Google OAuth ----------
# Register the OAuth client at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI (must be the punycode form):
#   https://xn--2t1b49b33i.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
