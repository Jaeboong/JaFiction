# Backend dev environment template
#
# Copy this file to packages/backend/.env.dev and fill in the Google OAuth
# credentials plus a random COOKIE_SECRET. Jasojeon scripts will refuse to boot
# the backend until .env.dev exists.

# Postgres connection string (matches docker-compose.dev.yml)
DATABASE_URL=postgres://jasojeon:devpass@localhost:5433/jasojeon

# Redis connection string (matches docker-compose.dev.yml)
REDIS_URL=redis://localhost:6380

# Google OAuth 2.0 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cookie signing secret — minimum 32 characters, generate with: openssl rand -hex 32
COOKIE_SECRET=change-me-to-a-32-char-or-longer-random-string

# HTTP port the dev backend listens on
PORT=4000

# Node environment
NODE_ENV=development

# Public base URL used for OAuth callback redirect and post-login redirect
PUBLIC_BASE_URL=http://localhost:4000
