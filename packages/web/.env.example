# Jasojeon web — environment variables
#
# Copy this file to `.env.local` and fill in the values you need. Vite loads
# any variable prefixed with `VITE_` into import.meta.env at build time.

# --- Hosted backend base URL ------------------------------------------------
# The web UI talks to the hosted backend via:
#   - POST ${VITE_HOSTED_API_BASE}/api/rpc with the session cookie
#   - ${VITE_HOSTED_API_BASE}/ws/events as a single multiplexed WS stream
#     carrying state_snapshot, run_event, intervention_request, and
#     run_finished envelopes
#
# If unset, the UI defaults to window.location.origin (same-origin deploy).
#
# VITE_HOSTED_API_BASE=https://api.jasojeon.app
