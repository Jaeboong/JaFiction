# JaFiction web — environment variables
#
# Copy this file to `.env.local` and fill in the values you need. Vite loads
# any variable prefixed with `VITE_` into import.meta.env at build time.

# --- Local mode (default) ---------------------------------------------------
# The web UI talks directly to the local runner on the user's machine.
#
# VITE_RUNNER_BASE_URL overrides the auto-derived localhost runner URL.
# If unset, the UI builds the URL from window.location + VITE_RUNNER_PORT.
#
# VITE_RUNNER_PORT     # runner listen port (default: 4123)
# VITE_RUNNER_BASE_URL # e.g. http://127.0.0.1:4123
# VITE_BACKEND_BASE_URL # backend origin for /api/pairing + /api/devices

# --- Hosted mode ------------------------------------------------------------
# Setting VITE_HOSTED_API_BASE switches the UI into hosted mode. In hosted
# mode:
#   - all RPC is routed through POST ${VITE_HOSTED_API_BASE}/api/rpc
#     with the session cookie (credentials: "include")
#   - the WebSocket connects to ${VITE_HOSTED_API_BASE}/ws/events as a
#     single multiplexed stream carrying state_snapshot, run_event,
#     intervention_request, and run_finished envelopes
#   - no localhost runner URL is baked into the bundle
#
# Leave this unset for local development; set it for hosted deployments.
#
# VITE_HOSTED_API_BASE=https://api.jafiction.app
